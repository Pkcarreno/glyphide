{
  "name": "glyphide",
  "type": "module",
  "version": "2.3.0",
  "description": "Write, run, and share JavaScript code instantly",
  "author": "Pedro Carreño (34664891+Pkcarreno@users.noreply.github.com)",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "turbo check",
    "tsc": "turbo run tsc",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "preinstall": "npx only-allow pnpm",
    "commitlint": "commitlint",
    "prepare": "lefthook install",
    "postinstall": "turbo run build --filter=@glyphide/quickjs",
    "root:knip": "knip",
    "knip": "turbo run root:knip",
    "clean": "node scripts/clean.js"
  },
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "knip": "^6.1.1",
    "lefthook": "^2.1.4",
    "turbo": "^2.9.2",
    "typescript": "^6.0.2",
    "ultracite": "^7.4.2"
  },
  "osMetadata": {
    "initVersion": "1.3.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pkcarreno/glyphide.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
